NEXT_PUBLIC_APP_VERSION=0.1.1
NEXT_PUBLIC_APP_URL=https://kouden-app.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=

# Gemini
GEMINI_API_KEY=

# Resend
RESEND_FROM_EMAIL=noreply@kouden-app.com
RESEND_API_KEY=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Calendar API
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# セキュリティ強化
# CSRF_SECRET: 必須・最低32文字。未設定だとアプリは起動失敗する。
# 生成例: openssl rand -hex 32
CSRF_SECRET=
SLACK_WEBHOOK_URL= #オプションで設定するかも?
SECURITY_LOG_LEVEL="info" #本番環境では空にするかfalseにする
MAX_FILE_SIZE="10485760" #10MB
ADMIN_SESSION_TIMEOUT="1800"
MAX_LOGIN_ATTEMPTS="5" #最大ログイン試行回数
ACCOUNT_LOCK_DURATION="30"